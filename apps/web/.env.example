# Production API URL (Vercel → Settings → Environment Variables)
# Leave empty in local dev — Vite proxy handles /api
# For Vercel demo deploy: leave empty OR set VITE_DEMO_MODE=true (see vercel.json)
# VITE_API_URL=https://your-api.example.com

# Demo mode — all data in browser localStorage, no backend required
# Enabled automatically on Vercel via vercel.json build env
# VITE_DEMO_MODE=true

# Web Push VAPID public key (same as VAPID_PUBLIC_KEY on API)
# VITE_VAPID_PUBLIC_KEY=
