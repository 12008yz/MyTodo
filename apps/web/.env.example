# Production API URL (Vercel → Settings → Environment Variables)
# Leave empty in local dev — Vite proxy handles /api
# VITE_API_URL=https://your-api.example.com

# Demo mode — browser-only data, no backend.
# `pnpm dev` + Docker/API: forced off via .env.development
# `pnpm dev:demo`: vite --mode demo (loads .env.demo)
# Vercel static demo: vercel.json sets VITE_DEMO_MODE=true
# VITE_DEMO_MODE=true

# Web Push VAPID public key (same as VAPID_PUBLIC_KEY on API)
# VITE_VAPID_PUBLIC_KEY=
